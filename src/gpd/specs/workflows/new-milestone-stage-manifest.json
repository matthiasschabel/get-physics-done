      ],
      "required_init_fields": [
        "researcher_model",
        "synthesizer_model",
        "project_contract_gate",
        "contract_intake",
        "effective_reference_intake",
        "reference_artifact_files",
        "literature_review_files",
        "research_map_reference_files"
      ],
      "loaded_authorities": [
        "workflows/new-milestone/survey-objectives.md",
        "references/orchestration/runtime-delegation-note.md",
        "references/research/questioning.md"
      ],
      "conditional_authorities": [],
      "must_not_eager_load": [
        "workflows/new-milestone.md",
        "workflows/new-milestone/roadmap-authoring.md",
        "references/ui/ui-brand.md",
        "templates/project.md",
        "templates/requirements.md"
      ],
      "allowed_tools": [
        "ask_user",
        "file_read",
        "file_write",
        "shell",
        "task"
      ],
      "writes_allowed": [
        "GPD/PROJECT.md",
        "GPD/STATE.md",
        "GPD/literature"
      ],
      "produced_state": [
        "research intake state",
        "milestone objective state",
        "project update state"
      ],
      "next_stages": [
        "roadmap_authoring"
      ],
      "checkpoints": [
        "prior milestone context reviewed",
        "survey choice and objective scope captured"
      ]
    },
    {
      "id": "roadmap_authoring",
      "order": 3,
      "purpose": "requirements synthesis, roadmap authoring, and downstream handoff",
      "mode_paths": [
        "workflows/new-milestone/roadmap-authoring.md"
      ],
      "required_init_fields": [
        "roadmapper_model",
        "current_milestone",
        "current_milestone_name",
        "project_contract",
        "project_contract_gate",
        "project_contract_load_info",
        "project_contract_validation",
        "contract_intake",
        "effective_reference_intake",
        "reference_artifact_files",
        "literature_review_files",
        "research_map_reference_files"
      ],
      "loaded_authorities": [
