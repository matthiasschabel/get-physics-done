        "session routing state",
        "verification preflight state"
      ],
      "next_stages": [
        "phase_bootstrap"
      ],
      "checkpoints": [
        "active session check completed",
        "review preflight completed",
        "contract gate remains visible"
      ]
    },
    {
      "id": "phase_bootstrap",
      "order": 2,
      "purpose": "proof gate resolution and bootstrap-only verification setup",
      "mode_paths": [
        "workflows/verify-work/phase-bootstrap.md"
      ],
      "required_init_field_groups": [
        "phase_target_base",
        "contract_gate_status"
      ],
