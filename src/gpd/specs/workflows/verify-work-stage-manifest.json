        "proof_redteam_finalizer_bridge"
      ],
      "loaded_authorities": [
        "workflows/verify-work/phase-bootstrap.md",
        "references/verification/core/proof-redteam-workflow-gate.md"
      ],
      "conditional_authorities": [],
      "must_not_eager_load": [
        "workflows/verify-work.md",
        "workflows/verify-work/session-router.md",
        "workflows/verify-work/inventory-build.md",
        "workflows/verify-work/interactive-validation.md",
        "workflows/verify-work/gap-repair.md",
        "references/verification/core/proof-redteam-protocol.md",
        "templates/proof-redteam-schema.md",
        "references/verification/core/verification-core.md",
        "references/verification/meta/verification-independence.md",
        "references/protocols/error-propagation-protocol.md",
        "references/shared/canonical-schema-discipline.md",
        "templates/research-verification.md",
        "templates/verification-report.md",
        "templates/contract-results-schema.md"
      ],
      "allowed_tools": [
        "ask_user",
        "file_read",
        "find_files",
        "search_files",
        "shell",
        "task"
      ],
      "writes_allowed": [],
      "produced_state": [
        "proof gate state",
        "bootstrap verification state"
      ],
      "next_stages": [
        "inventory_build"
      ],
      "checkpoints": [
        "proof-readiness context loaded; classify proof-bearing status from inspected proof metadata",
        "bootstrap gate remains fail-closed"
      ]
    },
    {
      "id": "inventory_build",
      "order": 3,
      "purpose": "delegated verifier handoff, anchor context loading, and report sync",
      "mode_paths": [
        "workflows/verify-work/inventory-build.md"
      ],
      "required_init_field_groups": [
        "phase_target_base",
        "contract_gate_status",
        "reference_handle_context",
        "protocol_bundle_handles"
      ],
      "required_init_fields": [
        "contract_intake",
        "convention_lock",
        "convention_lock_count",
        "derived_convention_lock",
        "derived_convention_lock_count",
        "verification_report_finalizer_bridge",
        "verification_report_skeleton_bridge"
      ],
      "loaded_authorities": [
        "workflows/verify-work/inventory-build.md"
      ],
      "conditional_authorities": [
        {
          "when": "full_independence_policy_check",
          "authorities": [
            "references/verification/meta/verification-independence.md"
          ]
        }
      ],
      "must_not_eager_load": [
        "workflows/verify-work.md",
        "workflows/verify-work/interactive-validation.md",
        "workflows/verify-work/gap-repair.md",
        "references/verification/core/verification-core.md",
        "references/verification/meta/verification-independence.md",
        "references/shared/canonical-schema-discipline.md",
        "references/protocols/error-propagation-protocol.md",
        "templates/research-verification.md",
        "templates/verification-report.md",
        "templates/contract-results-schema.md",
        "templates/planner-subagent-prompt.md"
      ],
      "allowed_tools": [
        "ask_user",
        "file_read",
        "find_files",
        "search_files",
        "shell",
        "task",
        "mcp__gpd_verification__get_bundle_checklist",
        "mcp__gpd_verification__suggest_contract_checks",
        "mcp__gpd_verification__run_contract_check"
      ],
      "writes_allowed": [],
      "produced_state": [
        "delegated verification state",
        "anchor context",
        "handoff routing state"
      ],
      "next_stages": [
        "interactive_validation"
      ],
      "checkpoints": [
        "verifier delegation completed",
        "handoff remains fail-closed",
        "anchor obligations explicit"
      ]
    },
    {
      "id": "interactive_validation",
      "order": 4,
      "purpose": "writer-stage session overlay and researcher response capture",
      "mode_paths": [
        "workflows/verify-work/interactive-validation.md"
      ],
      "required_init_field_groups": [
        "phase_target_base",
        "contract_gate_status"
      ],
      "required_init_fields": [
        "contract_intake",
        "reference_artifact_files"
      ],
      "loaded_authorities": [
        "workflows/verify-work/interactive-validation.md"
      ],
      "conditional_authorities": [
        {
          "when": "session_overlay_write_or_repair",
          "authorities": [
            "templates/research-verification.md",
            "templates/verification-report.md",
            "templates/contract-results-schema.md",
            "references/shared/canonical-schema-discipline.md"
          ]
        },
        {
          "when": "custom_verifier_continuation",
          "authorities": [
            "templates/verification-report.md",
            "templates/contract-results-schema.md",
            "references/shared/canonical-schema-discipline.md"
          ]
        }
      ],
      "must_not_eager_load": [
        "workflows/verify-work.md",
        "workflows/verify-work/gap-repair.md",
        "references/protocols/error-propagation-protocol.md",
        "references/verification/core/verification-core.md",
        "references/verification/meta/verification-independence.md",
        "references/shared/canonical-schema-discipline.md",
        "templates/research-verification.md",
        "templates/verification-report.md",
        "templates/contract-results-schema.md",
        "templates/planner-subagent-prompt.md"
      ],
      "allowed_tools": [
        "ask_user",
        "file_read",
        "file_edit",
        "file_write",
        "find_files",
        "search_files",
        "shell",
        "task"
      ],
      "writes_allowed": [
        "GPD/phases/XX-name/XX-VERIFICATION.md"
      ],
      "produced_state": [
        "verification report draft",
        "validation results",
        "session continuation state"
      ],
      "next_stages": [
        "gap_repair"
      ],
      "checkpoints": [
        "verification file can be written",
        "writer-stage schema deferral barrier is visible",
        "check results remain contract-backed"
      ]
    },
    {
      "id": "gap_repair",
      "order": 5,
      "purpose": "diagnosis, gap planning, and verified closeout after failed checks",
      "mode_paths": [
        "workflows/verify-work/gap-repair.md"
      ],
      "required_init_field_groups": [
        "phase_target_base",
        "contract_gate_status",
        "gap_repair_targeted_reference_context"
      ],
      "required_init_fields": [],
      "loaded_authorities": [
        "workflows/verify-work/gap-repair.md"
      ],
      "conditional_authorities": [
        {
          "when": "gap_report_write_or_schema_repair",
          "authorities": [
            "templates/research-verification.md",
            "templates/verification-report.md",
            "templates/contract-results-schema.md",
            "references/shared/canonical-schema-discipline.md"
          ]
        },
        {
          "when": "error_propagation_gap",
          "authorities": [
            "references/protocols/error-propagation-protocol.md"
          ]
        }
      ],
      "must_not_eager_load": [
        "workflows/verify-work.md",
        "references/protocols/error-propagation-protocol.md",
        "references/shared/canonical-schema-discipline.md",
        "templates/research-verification.md",
        "templates/verification-report.md",
        "templates/contract-results-schema.md"
      ],
      "allowed_tools": [
        "ask_user",
        "file_read",
        "file_edit",
        "file_write",
        "find_files",
        "search_files",
        "shell",
        "task"
      ],
      "writes_allowed": [
        "GPD/phases/XX-name/XX-VERIFICATION.md"
      ],
      "produced_state": [
        "diagnosed gaps",
        "repair plans",
        "verification closeout"
      ],
      "next_stages": [],
      "checkpoints": [
        "gaps are diagnosed",
        "repair plans are verified",
        "verification closeout is ready"
      ]
    }
  ]
}
